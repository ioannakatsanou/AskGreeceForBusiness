# TenderFit AI — backend environment (Phase 2 scaffold, mock-first)
PORT=3001
NODE_ENV=development

# Procurement data source: "mock" only for now. ESIDIS/KIMDIS not implemented yet.
PROCUREMENT_SOURCE_MODE=mock

# Search guards
SEARCH_TIMEOUT_MS=10000
SEARCH_MAX_RESULTS=5

# CORS — comma-separated allowed origins. "*" allows any (dev convenience).
# In production set this to the GitHub Pages origin + localhost, e.g.:
#   ALLOWED_ORIGIN=https://ioannakatsanou.github.io,http://localhost:5173
ALLOWED_ORIGIN=*
